{
  "name": "md-path-mentions-autocomplete",
  "displayName": "MD Path Mentions: AI Prompt File Links",
  "description": "Type @ in markdown to precisely reference a project file or folder — no more typos in paths for AI prompts",
  "version": "0.1.1",
  "publisher": "Yakub",
  "icon": "assets/logo.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NereonNeo/markdown-autocomplete.git"
  },
  "keywords": [
    "markdown",
    "autocomplete",
    "path",
    "mention",
    "prompt",
    "ai",
    "llm",
    "prompt-engineering",
    "context",
    "cursor",
    "copilot",
    "chatgpt",
    "claude"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Chat"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mdPathMentions.rebuildIndex",
        "title": "MD Path Mentions: Rebuild Index"
      }
    ],
    "configuration": {
      "title": "MD Path Mentions",
      "properties": {
        "mdPathMentions.excludeGlobs": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/out/**",
            "**/build/**"
          ],
          "description": "Glob patterns excluded from the index"
        },
        "mdPathMentions.maxFiles": {
          "type": "number",
          "default": 8000,
          "description": "Limit of files in the index"
        },
        "mdPathMentions.includeDirectories": {
          "type": "boolean",
          "default": true,
          "description": "Show directories in the autocomplete list"
        },
        "mdPathMentions.maxSuggestions": {
          "type": "number",
          "default": 300,
          "description": "Maximum number of suggestions shown per autocomplete query"
        },
        "mdPathMentions.trace": {
          "type": "boolean",
          "default": false,
          "description": "Verbose debug logs in the 'MD Path Mentions' Output channel (for troubleshooting)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
